{
  "src": ["./src"],
  "extension": [".ts"],
  "exclude": [
    "**/*.d.ts",
    "**/*.test.ts",
    "test/**/*",
    "dist/**/*",
    "coverage/**",
    "bin/**/*",
    "scripts/**/*",
    "tmp/**/*",
    "**/*.mjs"
  ],
  "include": ["src/**/*.ts"],
  "reporter": ["text-summary", "html", "lcov"],
  "all": true,
  "excludeAfterRemap": true,
  "allowExternal": false,
  "statements": 60,
  "branches": 60,
  "functions": 60,
  "lines": 60
}
